# AI 教学智能体 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ========== Kimi AI 配置 ==========
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ========== 数据库配置 ==========
# 主业务数据库
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=ai_teaching_assistant

# 答疑专用数据库
QA_DB_HOST=localhost
QA_DB_PORT=3306
QA_DB_USER=root
QA_DB_PASSWORD=your_mysql_password_here
QA_DB_NAME=ai_qa_records

# RAG 知识库数据库
RAG_DB_HOST=localhost
RAG_DB_PORT=3306
RAG_DB_USER=root
RAG_DB_PASSWORD=your_mysql_password_here
RAG_DB_NAME=ai_rag_knowledge

# ========== 其他配置 ==========
# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 文件上传大小限制 (MB)
MAX_UPLOAD_SIZE=50

# RAG 检索相似度阈值 (0-1)
RAG_SIMILARITY_THRESHOLD=0.8
